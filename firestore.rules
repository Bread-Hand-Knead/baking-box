rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "linda6623@gmail.com" || 
         request.auth.token.email == "linda6623@gamil.com");
    }
    function isDocOwner() {
      // Support both uid and author_id for flexibility during transition
      return isAuthenticated() && 
        (request.auth.uid == resource.data.get('author_id', '') || 
         request.auth.uid == resource.data.get('uid', ''));
    }
    function uidUnchanged() {
      return (!('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid) &&
             (!('author_id' in request.resource.data) || request.resource.data.author_id == request.auth.uid);
    }
    function uidNotModified() {
      return (!('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid) &&
             (!('author_id' in request.resource.data) || request.resource.data.author_id == resource.data.author_id);
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if isAuthenticated() && (isAdmin() || resource == null || isDocOwner());
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.get('author_id', '') == request.auth.uid || request.resource.data.get('uid', '') == request.auth.uid);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner()) && uidNotModified();
      allow delete: if isAuthenticated() && (isAdmin() || isDocOwner());
    }
  }
}
