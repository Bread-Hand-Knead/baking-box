rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "linda6623@gmail.com" && request.auth.token.email_verified == true);
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function isValidRecipe(data) {
      return data.uid is string && data.title is string && data.title.size() > 0 && data.title.size() < 100;
    }
    function isValidCategory(data) {
      return data.uid is string && data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    match /userSettings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if isAuthenticated() && (isAdmin() || resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidRecipe(request.resource.data) && (isAdmin() || request.resource.data.uid == request.auth.uid);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner()) && isValidRecipe(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (isAdmin() || isDocOwner());
    }
  }
}
