rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "linda6623@gmail.com" || 
        request.auth.token.email == "linda6623@gamil.com"
      );
    }

    // Helper: Validate Identity in data
    function isInputOwner(data) {
      // Handle potential nulls or missing fields by forcing a match against a non-matchable default if missing
      return (data.get('uid', '') == request.auth.uid) || 
             (data.get('author_id', '') == request.auth.uid);
    }

    // Helper: check if existing doc is owned
    function isDocOwner() {
      return (existing().get('uid', '') == request.auth.uid) || 
             (existing().get('author_id', '') == request.auth.uid);
    }

    // Helper: Validate Recipe data shape (Pillar 2)
    function isValidRecipe(data) {
      return data.keys().hasAll(['title', 'category'])
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 100
        && (!('uid' in data) || (data.uid is string || data.uid == null))
        && (!('author_id' in data) || (data.author_id is string || data.author_id == null));
    }

    // Match Blocks
    
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /user_categories/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /recipes/{recipeId} {
      // Pillar 8: Secure List Queries
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource == null) || // For gets that don't exist
        isDocOwner()
      );

      allow create: if isVerified() && isValidId(recipeId) && isValidRecipe(incoming()) && (
        isAdmin() || isInputOwner(incoming())
      );

      allow update: if isVerified() && isValidRecipe(incoming()) && (
        isAdmin() || (
          isDocOwner() && 
          // Pillar 4 & 9: Immutable Identity (Allowed to set if currently empty/missing)
          (existing().get('uid', '') == '' || incoming().get('uid', '') == existing().get('uid', '')) &&
          (existing().get('author_id', '') == '' || incoming().get('author_id', '') == existing().get('author_id', ''))
        )
      );

      allow delete: if isSignedIn() && (
        isAdmin() || isDocOwner()
      );
    }
    
    match /drafts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Interaction Collections (Pillar 1)
    match /user_knowledge/{knowledgeId} {
      allow read, write: if isSignedIn() && (isAdmin() || resource.data.uid == request.auth.uid || incoming().uid == request.auth.uid);
    }
  }
}
